# Normalize line endings to LF on commit; check out native on Windows.
* text=auto eol=lf

# Force LF for known-text formats (avoids CRLF warnings on Windows).
*.js   text eol=lf
*.jsx  text eol=lf
*.json text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# Binaries — git should never try to diff or convert these.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
